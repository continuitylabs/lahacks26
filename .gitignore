# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# OS
.DS_Store
*.pem

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Metro
.metro-health-check*

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*

# Native — signing keys & profiles (never commit)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# iOS (prebuild output IS tracked — ignore only build artifacts & per-user state)
ios/Pods/
ios/build/
ios/DerivedData/
ios/.xcode.env.local
ios/**/xcuserdata/
ios/**/*.xcuserstate

# Android (prebuild output IS tracked — ignore only build artifacts & per-user state)
android/.gradle/
android/.idea/
android/.cxx/
android/app/build/
android/app/.cxx/
android/build/
android/local.properties
.kotlin/

# Local env files
.env*.local

# TypeScript
*.tsbuildinfo

# Reset script scratch
app-example
