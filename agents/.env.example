# ── Agentverse / ASI:One ─────────────────────────────────────────────────────
# Get one at https://agentverse.ai → Profile → API keys
# Required to publish the rescue coordinator to ASI:One.
AGENTVERSE_API_KEY=

# ── uAgent seeds (any unique strings; addresses derive from these) ──────────
# Keep these stable so the same wallet/address is used across runs.
RESCUE_COORDINATOR_SEED=northstar-rescue-coordinator-seed-CHANGE-ME
LOCATION_SCOUT_SEED=northstar-location-scout-seed-CHANGE-ME
MEDICAL_COORDINATOR_SEED=northstar-medical-coordinator-seed-CHANGE-ME
CONTACT_ORCHESTRATOR_SEED=northstar-contact-orchestrator-seed-CHANGE-ME
# The Phone Agent represents the user's device in the agent network.
# The Expo app POSTs to its REST endpoint; it forwards as a ChatMessage.
PHONE_AGENT_SEED=northstar-phone-agent-seed-CHANGE-ME

# ── Anthropic (medical reasoning + chat parsing + script drafting) ──────────
# https://console.anthropic.com — without this, agents fall back to heuristics.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# ── ElevenLabs (voice synthesis for the dispatcher script) ──────────────────
# https://elevenlabs.io → Profile → API key. Without this the orchestrator
# returns the script as text only.
ELEVENLABS_API_KEY=
# A calm, clear voice ID — default is the "Rachel" preset.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Twilio (places the actual emergency call) ───────────────────────────────
# https://console.twilio.com. Without these the orchestrator drafts the call
# but does not place it.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# DEMO ONLY — for the live demo, use your own phone, not 911.
TWILIO_TO_NUMBER=
CALL_TARGET_NUMBER=+14084386340
CALL_BRIDGE_PORT=8787
# Optional public base URL for Twilio <Play> to fetch ElevenLabs MP3 audio.
# Without this, the bridge falls back to Twilio <Say>.
PUBLIC_BASE_URL=

# ── Local Bureau ports ──────────────────────────────────────────────────────
RESCUE_COORDINATOR_PORT=8000
LOCATION_SCOUT_PORT=8001
MEDICAL_COORDINATOR_PORT=8002
CONTACT_ORCHESTRATOR_PORT=8003
PHONE_AGENT_PORT=8004
